# Allowlist repository inputs only. New files are ignored unless re-included
# below, keeping experiment outputs, datasets, papers, logs, and local agent
# state out of git by default.
*

# Keep only allowlisted directories traversable.
!configs/
!configs/publication/
!configs/publication/**/
!noisyflow/
!noisyflow/**/
!tests/
!tests/**/
!scripts/
!scripts/**/
!docs/
!docs/**/
!assets/
!requirements/
!requirements/**/

# Repository metadata and dependency manifests.
!.gitignore
!README.md
!LICENSE
!LICENSE.*
!requirements*.txt
!requirements*.in
!constraints*.txt
!constraints*.in
!environment*.yml
!environment*.yaml
!pyproject.toml
!setup.cfg
!setup.py
!MANIFEST.in

# Root Python entry points.
!run.py
!noisyflow_sketch.py

# Package source and tests.
!noisyflow/*.py
!noisyflow/**/*.py
!tests/*.py
!tests/**/*.py

# Scripts.
!scripts/*.py
!scripts/**/*.py
!scripts/*.sh
!scripts/**/*.sh

# Documentation.
!docs/*.md
!docs/**/*.md
!docs/*.rst
!docs/**/*.rst
!docs/*.txt
!docs/**/*.txt

# README assets.
!assets/Noisyflow-Mar24th-schematics-updated.pdf
!assets/schematics.pdf
!assets/noisyflow-main-schematic-600dpi.png
!assets/noisyflow-schematic-600dpi.png

# Requirement files in a requirements/ directory, if present.
!requirements/*.txt
!requirements/**/*.txt
!requirements/*.in
!requirements/**/*.in
!requirements/*.yml
!requirements/**/*.yml
!requirements/*.yaml
!requirements/**/*.yaml

# Configs: only publication configs are eligible for git.
!configs/publication/*.yaml
!configs/publication/**/*.yaml
!configs/publication/*.yml
!configs/publication/**/*.yml

# Local agent instructions and LaTeX sources stay ignored.
AGENTS.md
*.tex
tex/
